generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLE_USER {
  admin
  user
}

enum LABEL_CLASSIFICATION {
  organik
  non_organik
  b3
  bukan_sampah
}

model Users {
  id         String    @id @default(uuid()) @db.Uuid
  fullName   String    @map("full_name") @db.VarChar(100)
  username   String    @unique @db.VarChar(50)
  email      String    @unique @db.VarChar(100)
  role       ROLE_USER @default(user)
  avatar_url String?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt

  @@map("users")
}

model wasteCategories {
  id           String   @id @default(uuid()) @db.Uuid
  categoryCode String   @unique @map("category_code") @db.VarChar()
  categoryName String   @map("category_name") @db.VarChar()
  description  String?  @db.Text
  handlingTips String?  @map("handling_tips") @db.Text
  colorHex     String?  @map("color_hex") @db.VarChar()
  pointsReward Int      @map("points_reward")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("waste_categories")
}
