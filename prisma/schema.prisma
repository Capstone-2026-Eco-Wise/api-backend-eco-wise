generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLE_USER {
  admin
  user
}

enum LABEL_CLASSIFICATION {
  organik
  non_organik
  b3
  bukan_sampah
}

enum FAQ_CATEGORY {
  point
  system
  scan
}

model Users {
  id           String    @id @default(uuid()) @db.Uuid
  fullName     String    @map("full_name") @db.VarChar(100)
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(100)
  role         ROLE_USER @default(user)
  avatar_url   String?
  aiTokens     Int       @default(5) @map("ai_tokens") @db.Integer
  tokenResetAt DateTime  @map("token_reset_at")
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt

  ecoPoints           ecoPoints?
  scanHistories       scanHistory[]
  faqsCreated         faqs[]                @relation("FaqCreator")
  faqsEdited          faqs[]                @relation("FaqEditor")
  userTaskCompletions userTaskCompletions[]

  @@map("users")
}

model faqs {
  id          String   @id @default(uuid()) @db.Uuid
  question    String   @db.VarChar(255)
  answer      String   @db.Text
  category    String   @db.VarChar(100)
  orderNumber Int      @default(0) @map("order_number")
  isActive    Boolean  @default(false) @map("is_active")
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp

  creator Users? @relation("FaqCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  editor  Users? @relation("FaqEditor", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("faqs")
}

model wasteCategories {
  id           String   @id @default(uuid()) @db.Uuid
  categoryCode String   @unique @map("category_code") @db.VarChar()
  categoryName String   @map("category_name") @db.VarChar()
  description  String?  @db.Text
  handlingTips String?  @map("handling_tips") @db.Text
  colorHex     String?  @map("color_hex") @db.VarChar()
  pointsReward Int      @map("points_reward")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  scanHistories scanHistory[]
  dailyTasks    dailyTasks[]

  @@map("waste_categories")
}

model ecoPoints {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  totalPoints    Int      @default(0) @map("total_points") @db.Integer
  currentStreak  Int      @default(0) @map("current_streak") @db.Integer
  longestStreak  Int      @default(0) @map("longest_streak") @db.Integer
  lastActiveDate DateTime @default(now()) @map("last_active_date") @db.Date

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("eco_points")
}

model scanHistory {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  categoryId      String   @map("category_id") @db.Uuid
  imageUrl        String   @map("image_url") @db.Text
  confidenceScore Decimal  @map("confidence_score")
  rawPredictions  Json?    @map("raw_predictions") @db.JsonB
  pointEarned     Int      @map("point_earned")
  scannedAt       DateTime @default(now()) @map("scanned_at") @db.Timestamp

  user     Users           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category wasteCategories @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([scannedAt])
  @@map("scan_history")
}

model dailyTasks {
  id          String   @id @default(uuid()) @db.Uuid
  categoryId  String?  @db.Uuid
  taskName    String   @map("task_name") @db.VarChar(100)
  description String?  @db.Text
  pointReward Int      @db.Integer
  isActive    Boolean  @default(true) @map("is_active") @db.Boolean
  activeDate  DateTime @map("active_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  category            wasteCategories?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  userTaskCompletions userTaskCompletions[]

  @@map("daily_tasks")
}

model userTaskCompletions {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  taskId       String   @map("task_id") @db.Uuid
  taskDate     DateTime @map("task_date") @db.Date
  pointAwarded Int      @map("point_awarded") @db.Integer
  isCompleted  Boolean  @default(false) @map("is_completed") @db.Boolean
  completedAt  DateTime @default(now()) @map("completed_at") @db.Timestamp

  user Users      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task dailyTasks @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskDate])
  @@map("user_task_completions")
}
