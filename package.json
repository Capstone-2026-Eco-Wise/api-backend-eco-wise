{
  "name": "api-backend-eco-wise",
  "version": "1.0.0",
  "description": "Capstone Project Backend",
  "license": "ISC",
  "author": "ibrhm",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "dotenv -e .env.development -- nodemon --exec tsx ./src/server.ts",
    "dev:staging": "dotenv -e .env.staging -- nodemon --exec tsx ./src/server.ts",
    "dev:prod": "dotenv -e .env.production -- nodemon --exec tsx ./src/server.ts",
    "build": "prisma generate && tsc",
    "start:dev": "dotenv -e .env.development -- node ./dist/src/server.js",
    "start:staging": "dotenv -e .env.staging -- node ./dist/src/server.js",
    "start:prod": "dotenv -e .env.production -- node ./dist/src/server.js",
    "db:push:dev": "dotenv -e .env.development -- prisma db push",
    "db:push:staging": "dotenv -e .env.staging -- prisma db push",
    "db:push:prod": "dotenv -e .env.production -- prisma db push",
    "db:studio:dev": "dotenv -e .env.development -- prisma studio",
    "db:studio:staging": "dotenv -e .env.staging -- prisma studio",
    "db:studio:prod": "dotenv -e .env.production -- prisma studio",
    "db:generate:dev": "dotenv -e .env.development -- prisma generate",
    "db:generate:staging": "dotenv -e .env.staging -- prisma generate",
    "db:generate:prod": "dotenv -e .env.production -- prisma generate",
    "db:migrate:dev": "dotenv -e .env.development -- prisma migrate dev",
    "db:migrate:staging": "dotenv -e .env.staging -- prisma migrate dev",
    "db:migrate:prod": "dotenv -e .env.production -- prisma migrate dev",
    "db:migrate:reset:dev": "dotenv -e .env.development -- prisma migrate reset",
    "db:migrate:reset:staging": "dotenv -e .env.staging -- prisma migrate reset",
    "db:migrate:reset:prod": "dotenv -e .env.production -- prisma migrate reset",
    "lint": "tsc --noEmit && eslint ."
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.104.0",
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
